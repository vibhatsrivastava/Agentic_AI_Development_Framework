# Integration-specific environment variables for Terraform Drift Detector
# Copy this file to .env and fill in your AWS credentials

# AWS Credentials (for boto3 drift detection)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1

# Chroma Vector Store Configuration
CHROMA_COLLECTION_NAME=terraform_policies
CHROMA_PERSIST_DIR=./vector_store

