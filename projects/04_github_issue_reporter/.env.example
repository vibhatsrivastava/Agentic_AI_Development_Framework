# ─── GitHub Integration ──────────────────────────────────────────────────────
# Integration-specific environment variables for GitHub Issue Reporter Agent
# Copy this file to .env in this project directory and configure these values.
# Common variables (OLLAMA_*, VAULT_*, LOG_LEVEL) remain in repo-root .env only.

# ─── Single Repository Configuration (Legacy Mode) ──────────────────────────
# For single repository usage, configure these environment variables:

# GitHub Personal Access Token for API authentication
# Create at: https://github.com/settings/tokens
# Required scopes:
#   - 'public_repo' (for public repositories) - READ AND WRITE access
#   - 'repo' (for private repositories) - Full read/write access
# NOTE: Write permissions are required for posting comments (--issue and --auto-analyze modes)
GITHUB_TOKEN=ghp_your_github_token_here

# GitHub repository owner (username or organization)
GITHUB_REPO_OWNER=your_github_username

# GitHub repository name to analyze
GITHUB_REPO_NAME=your_repository_name

# ─── Microsoft Teams Integration (Optional) ──────────────────────────────────
# Microsoft Teams webhook URL for sending notifications when issue analysis completes
# Create an incoming webhook in your Teams channel:
#   1. Go to your Teams channel
#   2. Click "..." → Connectors → Incoming Webhook
#   3. Configure webhook and copy the URL
# Leave blank to disable Teams notifications (optional feature)
MS_TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-url

# ─── Multiple Repository Configuration ──────────────────────────────────────
# For multiple repositories, use the repos.json configuration file instead.
# See repos.json.example for configuration format.
# Supports:
#   1. Multiple repos with same token (set default_token in repos.json)
#   2. Multiple repos with different tokens (set per-repo token in repos.json)
# Usage: python src/main.py --repos-config repos.json --report

# ─── Microsoft Teams Integration (Optional) ──────────────────────────────────
# Microsoft Teams Incoming Webhook URL for sending report notifications
# Create webhook in Teams: Channel → Connectors → Incoming Webhook
# Leave blank to disable Teams notifications
# Usage: python src/main.py --report --send-teams
MS_TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-url
